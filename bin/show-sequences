#!/usr/bin/env python3
"""Strip terminal escape sequences from a file or stdin."""
import sys

from wcwidth import iter_sequences

if len(sys.argv) > 1:
    with open(sys.argv[1], "r", encoding="utf-8", errors="replace") as f:
        for line in f.readlines():
            for item, is_seq in iter_sequences(line):
                print(repr(item) if is_seq else item, end='')
            print('', flush=True)
        sys.stdout.write()
else:
    sys.stdout.write(strip_sequences(sys.stdin.read()))
